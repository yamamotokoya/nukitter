<%# app/views/layouts/_header_links.html.erb %>
<% if current_user&.admin? %>
  <div class="flex items-center bg-amber-500/10 px-2 py-1 rounded border border-amber-500/20">
    <span class="text-amber-500 text-[10px] font-bold mr-2">ADMIN</span>
    <%= link_to "タイムライン", root_path, class: "text-sm hover:text-amber-400" %>
    <%= link_to "配信者一覧", streamers_path, class: "text-sm hover:text-amber-400" %>
    <%= link_to "配信者登録", new_streamer_path, class: "text-sm hover:text-amber-400" %>
  </div>
<% end %>

<% if logged_in? %>
  <span class="text-sm text-slate-400"><%= current_user.name %></span>
  <%= button_to "ログアウト", logout_path, method: :delete, class: "text-sm text-left hover:text-red-400" %>
<% else %>
  <%= link_to "ログイン", login_path, class: "text-sm hover:underline" %>
  <%= link_to "新規登録", signup_path, class: "text-sm bg-indigo-600 px-3 py-1 rounded text-center" %>
<% end %>
