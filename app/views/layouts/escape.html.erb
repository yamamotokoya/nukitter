          <% @post.genres.each do |genre| %>
            <%= link_to genre_path(genre), class: "px-4 py-2 bg-indigo-50 text-indigo-600 text-sm font-bold rounded-full border border-indigo-100 hover:bg-indigo-600 hover:text-white transition shadow-sm" do %>
              # <%= genre.name %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# app/views/posts/show.html.erb の一番最後に追加 %>

<div class="max-w-4xl mx-auto px-4 mt-16 pb-20">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-bold text-gray-900 flex items-center">
      <span class="mr-2">📺</span> <%= @post.streamer.name %> の他の動画
    </h2>
    <%= link_to "すべて見る", streamer_path(@post.streamer), class: "text-sm font-bold text-indigo-600 hover:underline" %>
  </div>

  <% if @other_posts.any? %>
    <%# 横スクロール可能なコンテナ %>
    <div class="flex overflow-x-auto pb-6 gap-6 scrollbar-hide snap-x snap-mandatory">
      <% @other_posts.each do |other_post| %>
        <div class="min-w-[280px] md:min-w-[320px] snap-start bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition">
          <%= link_to post_path(other_post), class: "block group" do %>
            <%# サムネイル（動画の1コマ目） %>
            <div class="aspect-video bg-black relative">
              <% if other_post.video.attached? %>
                <%= video_tag url_for(other_post.video), class: "w-full h-full object-cover opacity-80 group-hover:opacity-100 transition" %>
              <% end %>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                <div class="bg-white/20 backdrop-blur-sm p-3 rounded-full">
                  <svg class="w-6 h-6 text-white fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            
            <%# 簡易タイトル（本文の冒頭） %>
            <div class="p-4">
              <p class="text-sm font-bold text-gray-800 line-clamp-2 leading-snug">
                <%= other_post.content %>
              </p>
              <p class="text-[10px] text-gray-400 mt-2">
                <%= other_post.created_at.strftime("%Y/%m/%d") %>
              </p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-400 text-sm italic">他の投稿はまだありません。</p>
  <% end %>
</div>

<style>
  /* スクロールバーを隠す（Chrome, Safari用） */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  /* スクロールバーを隠す（IE, Edge, Firefox用） */
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
<%# ----ここまで---- %>

<%# show.html.erb/users %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="max-w-6xl mx-auto py-10 px-4">
  <%# --- 1. ユーザープロフィールヘッダー --- %>
  <div class="bg-slate-900 rounded-3xl p-8 md:p-12 mb-12 shadow-xl border border-slate-800 flex flex-col md:flex-row items-center md:items-end space-y-6 md:space-y-0 md:space-x-8">
    <div class="w-24 h-24 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-full flex items-center justify-center text-white text-4xl font-black shadow-lg ring-4 ring-slate-800">
      <%= @user.name&.[](0) %>
    </div>
    
    <div class="flex-1 text-center md:text-left">
      <h1 class="text-3xl font-black text-white mb-2 tracking-tight"><%= @user.name %></h1>
      <div class="flex items-center justify-center md:justify-start space-x-4 text-slate-400 text-sm">
        <span class="flex items-center">
          <span class="text-red-500 mr-1.5 text-lg">❤️</span>
          <strong class="text-white mr-1"><%= @liked_posts.count %></strong> Likes
        </span>
        <span class="w-1 h-1 bg-slate-700 rounded-full"></span>
        <span>Member since <%= @user.created_at.strftime("%Y/%m") %></span>
      </div>
    </div>

    <% if current_user == @user %>
      <%= link_to edit_user_path(@user), class: "px-6 py-2.5 bg-slate-800 hover:bg-slate-700 text-white text-sm font-bold rounded-xl transition-all border border-slate-700 shadow-sm" do %>
        プロフィールを編集
      <% end %>
    <% end %>
  </div>

  <%# --- 2. 最近見た動画 (10件) --- %>
  <% if @history_posts.present? && @history_posts.any?  %>
    <div id="view_history_section" class="mb-16">
        <div class="flex items-center justify-between mb-6 px-1">
  <%# 左側：タイトル %>
  <h2 class="text-sm font-black text-gray-400 uppercase tracking-widest flex items-center">
    <span class="mr-2 text-lg">🕒</span> 最近見た動画 10件
  </h2>
  
  <%# 右側：削除リンク（aタグなのでレイアウトが壊れません） %>
  <%= link_to history_path, 
        data: { 
          turbo_method: :delete, 
          turbo_confirm: "視聴履歴をすべて削除しますか？" 
          
        }, 
        class: "flex items-center space-x-1.5 text-[10px] font-bold text-gray-400 hover:text-red-500 bg-gray-100 hover:bg-red-50 px-3 py-1.5 rounded-full transition-colors no-underline" do %>
    <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
    </svg>
    <span class="whitespace-nowrap">履歴を消去</span>
  <% end %>
</div>

      <div class="flex overflow-x-auto gap-6 pb-6 scrollbar-hide snap-x items-start">
        <% @history_posts.each do |post| %>
          <div class="w-60 flex-none snap-start group">
            <%= link_to post_path(post), class: "block w-full" do %>
              <div class="aspect-video bg-black rounded-xl overflow-hidden mb-3 border border-gray-100 shadow-sm group-hover:shadow-md transition relative">
                <% if post.video.attached? %>
                  <%= video_tag rails_storage_proxy_path(post.video), class: "w-full h-full object-cover block opacity-90 group-hover:opacity-100" %>
                <% end %>
              </div>
              <div class="px-1 text-left">
                <p class="text-[11px] font-bold text-gray-900 truncate mb-0.5"><%= post.streamer.name %></p>
                <p class="text-[10px] text-gray-500 truncate opacity-80"><%= post.content %></p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# --- 3. お気に入り動画セクション --- %>
  <div class="flex items-center justify-between mb-8 pb-4 border-b border-gray-200">
    <h2 class="text-xl font-extrabold text-gray-900 flex items-center">
      <span class="mr-3">📂</span> お気に入り動画
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-start w-full">
    <% if @liked_posts.any? %>
      <%= render partial: 'posts/post', collection: @liked_posts, as: :post %>
    <% else %>
      <div class="col-span-full py-32 text-center bg-white rounded-3xl border-2 border-dashed border-gray-200">
        <div class="text-5xl mb-6 opacity-30">🎬</div>
        <p class="text-gray-500 font-bold text-lg mb-6">まだ「いいね」した動画がありません</p>
        <%= link_to "タイムラインで動画を探す", root_path, class: "inline-flex items-center px-8 py-3 bg-indigo-600 text-white font-bold rounded-full hover:bg-indigo-700 transition shadow-lg shadow-indigo-200" %>
      </div>
    <% end %>
  </div>
</div>
<%# ----ここまで---- %>

    
