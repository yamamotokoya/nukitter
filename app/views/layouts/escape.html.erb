<div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow"> 
  <div class="p-5">
    <%# 配信者情報（ヘッダー） %>
    <div class="flex items-center mb-4">
      <%= link_to streamer_path(post.streamer), class: "flex items-center group" do %>
        <div class="h-10 w-10 rounded-full flex items-center justify-center font-bold text-lg mr-3 <%= streamer_avatar_class(post.streamer.name) %>">
          <%= post.streamer.name&.[](0) %>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-center">
          <p class="text-sm font-bold text-gray-900 group-hover:text-indigo-600 transition">
            <%= post.streamer.name %>
          </p>
          <% if post.streamer.x_url.present? %>
        <span class="hidden sm:inline mx-2 text-gray-300">|</span>
        <%= link_to post.streamer.x_url, target: "_blank", rel: "noopener", class: "text-xs text-gray-400 hover:text-sky-500 flex items-center transition" do %>
          <%# X風のアイコン（文字でも代用可） %>
          <span class="font-medium">@<%= post.streamer.x_url.split('/').last %></span>
          <svg class="w-3 h-3 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        <% end %>
      <% end %>
          
          <p class="text-xs text-gray-400 post_created_at">
            <%= time_ago_in_words(post.created_at) %>前
          </p>
        </div>
      <% end %>
    </div>

    <%# 投稿本文 %>
    <div class="flex flex-col h-full">
      <div class="text-gray-600 text-sm mb-4 break-words overflow-hidden flex-1 min-h-[4.5rem]"
          style="display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3;">
        <%= auto_link(post.content, html: { class: 'text-indigo-600 hover:underline' }) %>
      </div>

      <%# ジャンルバッジ：最下部に固定 %>
      <div class="flex flex-wrap gap-2 mt-auto pt-4 border-t border-gray-100">
        <% if post.genres.any? %>
          <% post.genres.each do |genre| %>
            <%= link_to genre_path(genre), class: "inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold bg-indigo-50 text-indigo-600 border border-indigo-100 shadow-sm whitespace-nowrap" do %>
              <span class="mr-0.5 text-indigo-400">#</span><%= genre.name %>
            <% end %>
          <% end %>
        <% else %>
          <span class="text-[10px] text-gray-400 italic px-1">ジャンル未設定</span>
        <% end %>
      </div>
    </div>


    <%# 動画がある場合 %>
    <% if post.video.attached? %>
      <div class="rounded-xl overflow-hidden bg-black aspect-video">
        <%= video_tag url_for(post.video), controls: true, class: "w-full h-full" %>
      </div>
    <% end %>
  </div>
</div>   


      <%# --- 3. サイドメニュー本体 (headerの外に出す) --- %>
      <div data-menu-target="content" 
           class="fixed inset-y-0 left-0 w-72 bg-slate-900 text-white shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out z-50 overflow-y-auto">
        <div class="p-6">
          <div class="flex items-center justify-between mb-8">
            <span class="text-xl font-bold">Menu</span>
            <button data-action="click->menu#toggle" class="text-slate-400 hover:text-white text-2xl">✕</button>
          </div>

          <%# サイドメニュー内検索窓 (スマホ用) %>
          <div class="mb-6 relative group">
            <% search_url = current_user&.admin? ? streamers_path : root_path %>
            <%= form_with url: search_url, method: :get, local: true, class: "relative", style: "display: block;" do |f| %>
              <%= f.text_field :query, value: params[:query], placeholder: "キーワード検索...", class: "w-full bg-slate-900 text-sm text-slate-200 pl-4 pr-12 py-3 rounded-xl border border-slate-700 outline-none" %>
              <button type="submit" class="absolute right-1.5 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center bg-indigo-600 text-white rounded-lg active:scale-90 transition-all">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              </button>
            <% end %>
          </div>

          <nav class="flex flex-col space-y-4">
            <%= link_to "タイムライン", root_path, class: "text-base py-2 hover:text-indigo-400 border-b border-slate-800" %>
            
            <%# ジャンル一覧 %>
            <div class="pt-4">
              <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3">ジャンル</p>
              <div class="flex flex-wrap gap-2">
                <% @sidebar_genres.each do |genre| %>
                  <%= link_to genre_path(genre), class: "text-xs bg-slate-800 hover:bg-indigo-600 hover:text-white px-3 py-1.5 rounded-full transition-colors border border-slate-700" do %>
                    <span class="text-slate-500 mr-0.5">#</span><%= genre.name %>
                    <span class="ml-1 text-[10px] text-slate-400 font-medium"><%= genre.posts_count %></span>
                  <% end %>
                <% end %>
              </div>
            </div>
            
            <%# 管理者メニュー %>
            <% if current_user&.admin? %>
              <div class="pt-4 border-t border-slate-800">
                <span class="bg-amber-500 text-slate-900 text-[10px] font-bold px-2 py-0.5 rounded uppercase">Admin Menu</span>
                <div class="flex flex-col space-y-2 mt-3 pl-2 border-l-2 border-amber-500/30 text-sm">
                  <%= link_to "配信者登録", new_streamer_path, class: "hover:text-amber-400" %>
                  <%= link_to "配信者一覧", streamers_path, class: "hover:text-amber-400" %>
                  <div class="pt-2">
                    <p class="text-xs text-slate-500 font-bold mb-1 underline">ユーザー管理</p>
                    <%= link_to "・ ユーザー一覧", users_path, class: "block hover:text-amber-400" %>
                    <%= link_to "・ 自分の編集", edit_user_path(current_user), class: "block hover:text-amber-400" %>
                  </div>
                </div>
              </div>
            <% end %>

            <%# ログイン/ログアウト %>
            <div class="pt-6 border-t border-slate-800">
              <% if logged_in? %>
                <div class="text-xs text-slate-400 mb-2 px-2">Login: <%= current_user.name %></div>
                <%= button_to "ログアウト", logout_path, method: :delete, class: "w-full text-left text-sm bg-slate-800 hover:bg-red-900/50 px-4 py-2 rounded" %>
              <% else %>
                <%= link_to "ログイン", login_path, class: "block text-sm text-center bg-slate-800 py-2 rounded" %>
                <%= link_to "新規登録", signup_path, class: "block text-sm text-center bg-indigo-600 py-2 rounded mt-2" %>
              <% end %>
            </div>
          </nav>
        </div>
      </div>

  <%# --- 2. 最近見た動画 (ヘッダーの「外」に配置する) --- %>
  <% if @history_posts&.any? %>
    <%= turbo_frame_tag "view_history_frame" do %>
    <div id="view_history_section" class="mb-12 transition-all duration-500 ease-in-out">
      <h2 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-6 flex items-center px-1">
        <span class="mr-2 text-lg">🕒</span> 最近見た動画10件
      </h2>
      <%# --- 履歴削除ボタン --- %>
      <%= button_to history_path, method: :delete, 
            data: { confirm: "視聴履歴をすべて削除しますか？" },
            class: "text-[10px] font-bold text-gray-400 hover:text-red-500 transition-all bg-gray-100 hover:bg-red-50 px-3 py-1.5 rounded-full"  do %>
            <%# class: "text-[10px] font-bold text-gray-400 hover:text-red-500 transition-colors flex items-center bg-gray-100 hover:bg-red-50 px-3 py-1.5 rounded-full mb-2" do %> 
        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        履歴を消去
      <% end %>
      
      <div class="flex flex-nowrap overflow-x-auto gap-6 pb-6 scrollbar-hide snap-x">
        <% @history_posts.each do |post| %>
          <div class="flex-none snap-start group" style="width: 240px;">
            <%= link_to post_path(post), class: "block w-full" do %>
              <div class="bg-black rounded-xl overflow-hidden mb-3 border border-gray-100 shadow-sm group-hover:shadow-md transition relative" 
                   style="width: 240px; height: 135px;">
                <% if post.video.attached? %>
                  <%= video_tag rails_storage_proxy_path(post.video), 
                                style: "width: 100%; height: 100%; object-fit: cover; display: block; opacity: 0.9;",
                                class: "group-hover:opacity-100 transition-opacity" %>
                <% end %>
                <div class="absolute inset-0 flex items-center justify-center bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity">
                  <div class="p-2 bg-white/20 backdrop-blur-sm rounded-full">
                    <svg class="w-6 h-6 text-white fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
              <div style="width: 240px;" class="px-1 text-left">
                <p class="text-[11px] font-bold text-gray-900 truncate mb-0.5"><%= post.streamer.name %></p>
                <p class="text-[10px] text-gray-500 truncate opacity-80"><%= post.content %></p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
    <% end %>
  <% end %>

  <%# _post.html.erb %>
  <div id="<%= dom_id post %>" class="group relative bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col h-full min-h-[400px]">
  
  <%# 1. カード全体をクリック可能にする透明な詳細リンク（最背面 z-10） %>
  <%= link_to post_path(post), class: "absolute inset-0 z-10" do %>
    <span class="sr-only">詳細を見る</span>
  <% end %>

  <%# 2. 動画エリア（再生ボタンを触れるように z-30） %>
  <div class="aspect-video bg-black flex-shrink-0 w-full overflow-hidden relative">
    <% if post.video.attached? %>
      <%= video_tag url_for(post.video), controls: true, preload: "metadata", class: "w-full h-full object-contain" %>
    <% end %>
  </div>

  <div class="p-5 flex-1 flex flex-col relative">
    <%# 3. 配信者情報セクション（リンクを効かせるため z-30） %>
    <div class="flex items-center mb-4 relative z-30">
      <%# アイコン：配信者一覧へ %>
      <%= link_to streamer_path(post.streamer), class: "w-9 h-9 rounded-full bg-indigo-600 flex-shrink-0 flex items-center justify-center text-white text-xs font-bold mr-3 hover:bg-indigo-500 transition shadow-sm" do %>
        <%= post.streamer.name&.[](0) %>
      <% end %>
      
      <div class="flex flex-col justify-center min-w-0">
        <div class="flex items-baseline space-x-2">
          <span class="text-sm font-extrabold text-gray-900 leading-tight truncate">
            <%= post.streamer.name %>
          </span>
          <%# Xリンク：ここを z-40 にして確実にクリック可能にする %>
          <% if post.streamer.x_url.present? %>
            <%= link_to post.streamer.x_url, target: "_blank", rel: "noopener", class: "text-[11px] text-indigo-400 hover:text-indigo-600 hover:underline font-bold truncate transition-colors relative z-40" do %>
              @<%= post.streamer.x_url %>
            <% end %>
          <% end %>
        </div>
        <span class="text-[10px] text-gray-400 font-medium tracking-wider mt-0.5">
          <%= time_ago_in_words(post.created_at) %>前
        </span>
      </div>
    </div>

    <%# 4. 本文エリア（クリック判定は背面の z-10 に任せるので z-20 ＆ pointer-events-none） %>
    <div class="text-gray-600 text-sm leading-relaxed mb-4 overflow-hidden flex-1 relative z-20 pointer-events-none" 
         style="display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; min-height: 4.2em; max-height: 4.2em;">
      <%= post.content %>
    </div>

    <div class="flex items-center space-x-4 mb-4 text-[11px] text-gray-400 font-medium">

    <div class="absolute bottom-4 right-4 z-50">
      <%= render "likes/like", post: post %>
    </div>
    </div>


    <%# 5. ジャンルバッジ（クリックを優先するため z-30） %>
    <div class="mt-auto pt-4 border-t border-gray-100 flex flex-wrap gap-2 relative z-30">
      <% post.genres.each do |genre| %>
        <%= link_to genre_path(genre), class: "px-2.5 py-1 rounded-full text-[10px] font-bold bg-indigo-50 text-indigo-600 border border-indigo-100 hover:bg-indigo-100 transition" do %>
          #<%= genre.name %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%# show.html.erb genres %>
<div class="max-w-4xl mx-auto py-8 px-4">
  <%# ヘッダー部分をカード風に装飾 %>
  <div class="mb-10 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <div class="h-12 w-12 bg-indigo-600 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-200">
        <span class="text-white font-bold text-xl">#</span>
      </div>
      <div>
        <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">
          <%= @genre.name %>
        </h1>
        <p class="text-sm text-gray-500 font-medium mt-0.5">ジャンル別の投稿一覧</p>
      </div>
    </div>

    <%# 投稿数バッジ %>
    <div class="text-right">
      <span class="block text-2xl font-black text-indigo-600 leading-none">
        <%= @posts_count %>
      </span>
      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1 block">Videos</span>
    </div>
  </div>

  <%# 投稿一覧（既存のグリッド） %>
  <div class="grid gap-6 md:grid-cols-2">
    <% if @posts.any? %>
      <%= render @posts %>
    <% else %>
      <%# 投稿がない時の表示（以前のコード） %>
      <div class="col-span-2 py-20 text-center bg-gray-50 rounded-xl border-2 border-dashed border-gray-200">
        <p class="text-gray-500">このジャンルの投稿はまだありません。</p>
      </div>
    <% end %>
  </div>
</div>


<html>
  <head>
    <title><%= content_for(:title) || "Product One Sample" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Product One Sample">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <div data-controller="menu">
      <%# --- 1. 上部バー (mainの外に置くことで端まで広がる) --- %>
      <header class="bg-slate-900 text-white shadow-md fixed top-0 w-full z-40 h-16 flex items-center px-4 justify-between">
        <div class="flex items-center">
          <button data-action="click->menu#toggle" class="p-2 hover:bg-slate-800 rounded-md focus:outline-none transition-colors">
            <svg class="h-6 w-6 fill-none stroke-current" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
          </button>
          <%= link_to "My App", root_path, class: "ml-4 text-xl font-bold tracking-tight shrink-0" %>
        </div>

        <%# --- 2. PC用の中央検索窓 --- %>
        <div class="hidden md:block w-full max-w-md mx-4">
          <% search_url = current_user&.admin? ? streamers_path : root_path %>
          <%= form_with url: search_url, method: :get, local: true, class: "relative w-full", style: "display: block;" do |f| %>
            <%= f.text_field :query, 
                  value: params[:query], 
                  placeholder: "キーワード検索...", 
                  class: "w-full bg-slate-800 text-sm text-slate-200 pl-4 pr-10 py-2 rounded-lg border border-slate-700 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all placeholder-slate-500" %>
            <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 p-1 text-slate-400 hover:text-white transition-colors">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </button>
          <% end %>
        </div>

        <div class="w-10 md:w-40"></div> <%# バランス調整用の空要素 %>
      </header>

      <%# --- サイドメニュー本体 --- %>
<div data-menu-target="content" 
     class="fixed inset-y-0 left-0 w-72 bg-slate-900 text-white shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out z-50 overflow-y-auto">
  <div class="p-6">
    <div class="flex items-center justify-between mb-8">
      <span class="text-xl font-bold tracking-tight text-indigo-400">Menu</span>
      <button data-action="click->menu#toggle" class="text-slate-400 hover:text-white text-2xl transition-colors">✕</button>
    </div>

    <%# 1. 検索窓 %>
    <div class="mb-8 relative">
      <% search_url = current_user&.admin? ? streamers_path : root_path %>
      <%= form_with url: search_url, method: :get, local: true, class: "relative w-full", style: "display: block;" do |f| %>
        <%= f.text_field :query, value: params[:query], placeholder: "キーワード検索...", class: "w-full bg-slate-950 text-sm text-slate-200 pl-4 pr-12 py-3 rounded-xl border border-slate-700 outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all placeholder-slate-600" %>
        <button type="submit" class="absolute right-1.5 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center bg-indigo-600 text-white rounded-lg active:scale-95 transition-all shadow-lg shadow-indigo-900/20">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>
      <% end %>
    </div>

    <nav class="flex flex-col space-y-6">
      <%= link_to "タイムライン", root_path, class: "text-base py-2 hover:text-indigo-400 border-b border-slate-800 transition font-bold" %>

      <%# --- 2. 最近いいねした動画 (Likeセクション) --- %>
      <%# --- 2. お気に入り、または履歴セクション --- %>
<% if logged_in? %>
  <% if @sidebar_likes&.any? %>
    <%# --- お気に入りがある場合 --- %>
    <div class="pt-2">
      <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-4 px-1 flex items-center">
        <span class="text-red-500 mr-1.5">❤️</span> お気に入り一覧
      </p>
      <div class="space-y-3">
        <% @sidebar_likes.each do |post| %>
          <%= link_to post_path(post), class: "group block p-2 rounded-lg hover:bg-slate-800 transition-all border border-transparent hover:border-slate-700" do %>
            <div class="flex items-center">
              <div class="w-8 h-8 rounded bg-slate-700 flex-shrink-0 flex items-center justify-center text-[10px] font-bold text-slate-400 group-hover:bg-indigo-600 group-hover:text-white transition-colors shadow-inner">
                <%= post.streamer.name&.[](0) %>
              </div>
              <div class="ml-3 overflow-hidden">
                <p class="text-[11px] font-bold text-slate-300 truncate group-hover:text-white"><%= post.streamer.name %></p>
                <p class="text-[10px] text-slate-500 truncate mt-0.5 group-hover:text-slate-400"><%= post.content %></p>
              </div>
            </div>
          <% end %>
        <% end %>
        <%= link_to user_path(current_user), class: "block text-center py-2 text-[10px] font-bold text-indigo-400 hover:text-indigo-300 transition" do %>
          すべて見る →
        <% end %>
      </div>
    </div>

  <% elsif @sidebar_histories&.any? %>
    <%# --- お気に入りがなく、履歴がある場合 --- %>
      <div class="pt-2">
        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-4 px-1 flex items-center">
          <span class="text-indigo-400 mr-1.5">🕒</span> 最近見た動画
        </p>
        <div class="space-y-3">
          <% @sidebar_histories.each do |post| %>
            <%= link_to post_path(post), class: "group block p-2 rounded-lg hover:bg-slate-800 transition-all border border-transparent hover:border-slate-700" do %>
              <div class="flex items-center">
                <div class="w-8 h-8 rounded bg-slate-700 flex-shrink-0 flex items-center justify-center text-[10px] font-bold text-slate-400 group-hover:bg-indigo-600 group-hover:text-white transition-colors shadow-inner">
                  <%= post.streamer.name&.[](0) %>
                </div>
                <div class="ml-3 overflow-hidden">
                  <p class="text-[11px] font-bold text-slate-300 truncate group-hover:text-white"><%= post.streamer.name %></p>
                  <p class="text-[10px] text-slate-500 truncate mt-0.5 group-hover:text-slate-400"><%= post.content %></p>
                </div>
              </div>
            <% end %>
          <% end %>
          <%= link_to user_path(current_user), class: "block text-center py-2 text-[10px] font-bold text-indigo-400 hover:text-indigo-300 transition" do %>
            履歴をすべて見る →
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>


      <%# --- 3. ジャンル一覧 --- %>
      <div class="pt-2">
        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 px-1">ジャンル</p>
        <div class="flex flex-wrap gap-2">
          <% @sidebar_genres.each do |genre| %>
