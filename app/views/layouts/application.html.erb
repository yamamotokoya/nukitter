<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "NuKitter" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%# app/views/layouts/application.html.erb の <head> 内 %>
    <script async src="https://platform.twitter.com" charset="utf-8" nonce="<%= content_security_policy_nonce %>"></script>
  </head>

  <body class="bg-gray-50 pt-0">
    <%# --- 全体を Stimulus Controller で包む --- %>
    <div data-controller="menu">
      
      <%# --- A. ヘッダーエリア（ロゴ・検索窓・メニューボタン） --- %>
      <div class="w-full px-6 pt-4 pb-4 flex flex-wrap items-center justify-between bg-white border-b border-gray-50">
        <div style="width: 100%; padding: 12px 24px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; background-color: transparent;">
          
          <div style="display: flex; align-items: center; width: 240px; flex-shrink: 0; margin-bottom: 0;">
            <%# メニューボタン：Frameの外にあるので、ランキングを切り替えても確実に反応します %>
            <button data-action="click->menu#toggle" 
                    class="group relative w-11 h-11 flex items-center justify-center bg-white text-slate-700 hover:text-indigo-600 rounded-xl border border-slate-100 shadow-sm transition-all active:scale-95 shrink-0 z-50 overflow-hidden">
              <svg class="h-6 w-6 fill-none stroke-current" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7"></path>
              </svg>
            </button>
            <span class="text-2xl font-black text-slate-900 tracking-tighter" style="margin-left: 24px; white-space: nowrap;">
              <%= link_to "NuKitter", root_path, data: { turbo_frame: "_top" } %>
            </span>
          </div>

          <div class="search-container" style="flex-grow: 1; display: flex; justify-content: center; min-width: 300px; order: 3;">
            <div style="width: 380px; max-width: 100%; position: relative;">
              <% search_url = current_user&.admin? ? streamers_path : root_path %>
              <%= form_with url: search_url, method: :get, local: true, data: { turbo_frame: "_top" } do |f| %>
                <div style="position: relative; width: 100%; display: flex; align-items: center;">
                  <%= f.text_field :query, value: params[:query], placeholder: "検索する...", style: "width: 100%; padding: 12px 55px 12px 20px; border-radius: 18px; border: 1px solid #e2e8f0; background-color: white; font-size: 14px; font-weight: bold; outline: none;" %>
                  <button type="submit" style="position: absolute; right: 6px; width: 38px; height: 38px; background-color: #4f46e5; color: white; border: none; border-radius: 14px; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 50;">
                    <svg style="width: 18px; height: 18px;" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                  </button>
                </div>
              <% end %>
            </div>
          </div>
          <div class="hidden-mobile" style="width: 240px; flex-shrink: 0;"></div>
        </div>
      </div>

      <%# --- B. オーバーレイ（背景の膜）：JSエラー防止のために必須 --- %>
      <div data-menu-target="overlay" data-action="click->menu#toggle" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>

      <%# --- C. サイドメニュー本体 --- %>
      <div id="side_menu_main" 
           data-turbo-permanent 
           data-menu-target="content" 
           class="fixed inset-y-0 left-0 w-72 bg-slate-900 text-white shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out z-50 overflow-y-auto">
               <div class="p-6">
      <div class="flex items-center justify-between mb-8">
        <span class="text-xl font-bold tracking-tight text-indigo-400">Menu</span>
        <button data-action="click->menu#toggle" class="text-slate-400 hover:text-white text-2xl">✕</button>
      </div>

      <nav class="flex flex-col space-y-6">
        <%# 1. タイムライン %>
        <%= link_to root_path, data: { turbo_frame: "_top" }, class: "group flex items-center py-2 px-1 text-sm font-bold text-slate-300 hover:text-indigo-400 border-b border-slate-800 transition-all" do %>
          <span class="w-6 h-6 flex items-center justify-center bg-slate-800 rounded mr-3 group-hover:bg-indigo-600 transition-colors text-xs">🏠</span>
          タイムライン
        <% end %>

        <%# 2. お気に入り or 履歴 %>
        <% if logged_in? %>
          <% if @sidebar_likes&.any? %>
            <div class="pt-2">
              <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-4 px-1 flex items-center">
                <span class="text-red-500 mr-1.5">❤️</span> お気に入り
              </p>
              <div class="space-y-2">
                <% @sidebar_likes.each do |post| %>
                  <%= link_to post_path(post), data: { turbo_frame: "_top" }, class: "group flex items-center p-2 rounded-lg hover:bg-slate-800 transition-all" do %>
                    <div class="w-8 h-8 rounded bg-slate-800 flex-shrink-0 flex items-center justify-center text-[10px] font-bold text-slate-400 group-hover:bg-indigo-600 group-hover:text-white">
                      <% if post.streamer.icon.attached? %>
                        <%= image_tag post.streamer.icon, class: "w-full h-full rounded-full object-cover" %>
                      <% else %>
                        <%= post.streamer.name&.[](0) %>
                      <% end %>
                    </div>
                    <div class="ml-3 overflow-hidden"><p class="text-[11px] font-bold text-slate-300 truncate group-hover:text-white"><%= post.streamer.name %></p></div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% elsif @sidebar_histories&.any? %>
            <div class="pt-2">
              <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-4 px-1 flex items-center">
                <span class="text-indigo-400 mr-1.5">🕒</span> 最近見た動画
              </p>
              <div class="space-y-2">
                <% @sidebar_histories.each do |post| %>
                  <%= link_to post_path(post), data: { turbo_frame: "_top" }, class: "group flex items-center p-2 rounded-lg hover:bg-slate-800 transition-all" do %>
                    <div class="w-8 h-8 rounded bg-slate-800 flex-shrink-0 flex items-center justify-center text-[10px] font-bold text-slate-400 group-hover:bg-indigo-600 group-hover:text-white">
                      <% if post.streamer.icon.attached? %>
                        <%= image_tag post.streamer.icon, class: "w-full h-full rounded-full object-cover" %>
                      <% else %>
                        <%= post.streamer.name&.[](0) %>
                      <% end %>
                    </div>
                    <div class="ml-3 overflow-hidden"><p class="text-[11px] font-bold text-slate-300 truncate group-hover:text-white"><%= post.streamer.name %></p></div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>

        <%# 3. ジャンル %>
        <div class="pt-2">
          <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-4 px-1 flex items-center">
            <span class="text-indigo-500 mr-1.5">#</span> ジャンル
          </p>
          <div class="flex flex-wrap gap-2 px-1">
            <% @sidebar_genres.each do |genre| %>
              <%= link_to genre_path(genre), data: { turbo_frame: "_top" }, class: "text-[10px] bg-slate-800 hover:bg-indigo-600 hover:text-white px-3 py-1.5 rounded-md border border-slate-700 transition-all flex items-center font-bold" do %>
                <span class="opacity-50 mr-1">#</span><%= genre.name %>
              <% end %>
            <% end %>
          </div>
        </div>
        
        <%# ランキング切り替え時に中身だけを入れ替えるための Turbo Frame %>
        <%= render 'shared/sidebar' %>
      </div>

      <main class="min-h-screen">
        <%= render 'shared/flash' rescue nil %>

        <div class="hidden">
          <%= turbo_frame_tag "sidebar_content" %>
        </div>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
