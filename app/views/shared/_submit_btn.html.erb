<%# data-controller="submit" を追加 %>
<div data-controller="submit">
  <%= f.submit btn_label, 
        data: { 
          submit_target: "button", 
          action: "click->submit#disable" 
        },
        class: "relative w-full h-10 px-4 bg-indigo-600 text-white rounded-md font-bold hover:bg-indigo-700 transition shadow-sm flex items-center justify-center text-sm disabled:bg-indigo-400 disabled:cursor-not-allowed" %>

  <%# ローディング時に表示されるスピナー（最初は hidden） %>
  <template data-submit-target="template">
    <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
    送信中...
  </template>
</div>
