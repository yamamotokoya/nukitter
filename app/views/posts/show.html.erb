<div class="max-w-4xl mx-auto py-10 px-4">
  <%# 戻るボタン %>
  <div class="mb-6">
    <%= link_to :back, class: "inline-flex items-center text-sm font-bold text-gray-500 hover:text-indigo-600 transition" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      戻る
    <% end %>
  </div>

  <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
    
    <%# 1. テキスト・詳細エリア %>
    <div class="p-8 md:p-12">
      <div class="text-gray-800 text-lg leading-relaxed break-words whitespace-pre-wrap mb-10 font-medium border-l-4 border-indigo-500 pl-6">
        <%= auto_link(@post.content, html: { class: 'text-indigo-600 hover:underline' }) %>
      </div>

      <%# 2. メイン表示エリア（作品 or サンプルの切り替え） %>
      <div class="aspect-video bg-slate-900 flex items-center justify-center rounded-xl overflow-hidden shadow-inner mb-10 relative group">
        
        <% if @post.affiliate_url.present? %>
          <%# --- アフィリエイト用：画像と誘導ボタンを表示 --- %>
          <%= link_to @post.affiliate_url, target: "_blank", rel: "nofollow", class: "w-full h-full relative block" do %>
            <% if @post.thumbnail.attached? %>
              <%= image_tag @post.thumbnail, class: "w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" %>
            <% end %>
            
            <%# 中央の誘導オーバーレイ %>
            <div class="absolute inset-0 flex flex-col items-center justify-center bg-black/20 group-hover:bg-black/40 transition-all">
              <div class="bg-indigo-600 text-white px-8 py-4 rounded-full font-black shadow-2xl transform group-hover:scale-110 transition-transform flex items-center gap-3">
                <span>公式サイトで作品サンプルを見る</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
              <p class="text-white/80 text-xs mt-4 font-bold tracking-widest uppercase">External Link: FANZA / MGS</p>
            </div>
          <% end %>

        <% elsif @post.x_video_url.present? %>
          <%# --- 従来通り：Xの作品プレイヤーを表示 --- %>
          <div id="x-embed-container" class="w-full max-w-[550px] mx-auto overflow-hidden">
            <blockquote class="twitter-video" data-media-max-width="560" data-lang="ja">
              <a href="<%= @post.x_video_url %>"></a>
            </blockquote>
          </div>
          <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
        <% else %>
          <div class="text-center">
            <p class="text-gray-500 font-bold">コンテンツを準備中です</p>
          </div>
        <% end %>
      </div>

      <%# ジャンルタグ等 %>
      <div class="pt-8 border-t border-gray-100">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">ジャンル</p>
        <div class="flex flex-wrap gap-3">
          <% @post.genres.each do |genre| %>
            <%= link_to genre_path(genre), class: "px-4 py-2 bg-indigo-50 text-indigo-600 text-sm font-bold rounded-full border border-indigo-100 hover:bg-indigo-600 hover:text-white transition shadow-sm" do %>
              # <%= genre.name %>
            <% end %>
          <% end %>
        </div>

        <%# 管理メニューセクション %>
        <% if current_user&.admin? %>
          <div class="mt-12 pt-8 border-t-2 border-dashed border-slate-100">
            <p class="text-[10px] font-black text-amber-500 uppercase tracking-[0.2em] mb-4 flex items-center">
              <span class="w-2 h-2 bg-amber-500 rounded-full mr-2 animate-pulse"></span>
              管理機能
            </p>
            <div class="flex flex-wrap gap-4">
              <%= link_to edit_post_path(@post), class: "inline-flex items-center px-6 py-3 bg-slate-900 text-white text-sm font-black rounded-xl shadow-lg hover:bg-indigo-600 hover:-translate-y-0.5 transition-all duration-200 group" do %>
                <svg class="w-4 h-4 mr-2 text-slate-400 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                編集
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# 下部の「他の作品」セクション %>
<div class="max-w-4xl mx-auto px-4 mt-16 pb-20">
  <div class="flex items-center justify-between mb-6 border-b-2 border-gray-100 pb-2">
    <h2 class="text-xl font-black text-gray-900 flex items-center">
      <span class="mr-2">📺</span> <%= @post.streamer.name %> の最新ラインナップ
    </h2>
    <%= link_to "すべて見る", streamer_path(@post.streamer), class: "text-sm font-bold text-indigo-600 hover:underline" %>
  </div>

  <% if @other_posts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @other_posts.each do |other_post| %>
        <%= render "posts/post", post: other_post %>
      <% end %>
    </div>
  <% end %>
</div>
