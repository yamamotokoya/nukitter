<div id="<%= dom_id post %>" class="group relative bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col h-full min-h-[400px]">
  
  <%# 1. 詳細リンク (z-10) - カードの余白クリックで詳細へ %>
  <%= link_to post_path(post), class: "absolute inset-0 z-10" do %>
    <span class="sr-only">詳細を見る</span>
  <% end %>

  <%# 2. 動画エリア (z-20) %>
  <div class="aspect-video bg-black flex-shrink-0 w-full overflow-hidden relative z-20 flex items-center justify-center">
    <% if post.x_video_url.present? %>
      <div class="w-full">
        <%# 動画特化モード (560は公式の動画モードフラグ) %>
        <blockquote class="twitter-video" data-media-max-width="560" data-lang="ja">
          <a href="<%= post.x_video_url %>"></a>
        </blockquote>
      </div>
    <% else %>
      <div class="text-gray-500 text-xs font-bold">動画がありません</div>
    <% end %>
  </div>

  <div class="p-5 flex-1 flex flex-col relative">
    <%# 3. 配信者情報 (z-30) %>
    <div class="flex items-center mb-4 relative z-30">
      <%= link_to streamer_path(post.streamer), class: "w-9 h-9 rounded-full bg-indigo-600 flex-shrink-0 flex items-center justify-center text-white text-xs font-bold mr-3 hover:bg-indigo-500 transition shadow-sm overflow-hidden" do %>
        <% if post.streamer.icon.attached? %>
          <%= image_tag post.streamer.icon, class: "w-full h-full object-cover" %>
        <% else %>
          <%= post.streamer.name&.[](0) %>
        <% end %>
      <% end %>
      
      <div class="flex flex-col justify-center min-w-0">
        <div class="flex items-baseline space-x-2">
          <span class="text-sm font-extrabold text-gray-900 leading-tight truncate"><%= post.streamer.name %></span>
          <% if post.streamer.x_url.present? %>
             <span class="text-[11px] text-indigo-400 font-bold truncate">@<%= post.streamer.x_url.split('/').last %></span>
          <% end %>
        </div>
        <span class="text-[10px] text-gray-400 mt-0.5"><%= time_ago_in_words(post.created_at) %>前</span>
      </div>
    </div>

    <%# 4. 本文エリア (z-20) %>
    <div class="text-gray-600 text-sm leading-relaxed mb-6 overflow-hidden relative z-20 pointer-events-none" 
         style="display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; min-height: 4.2em; max-height: 4.2em;">
      <%= post.content %>
    </div>

    <%# 5. フッターエリア (z-30) %>
    <div class="mt-auto pt-4 border-t border-gray-100 relative z-30">
      <div class="flex flex-wrap gap-2 mb-4">
        <% post.genres.each do |genre| %>
          <%= link_to genre_path(genre), class: "px-2.5 py-1 rounded-full text-[10px] font-bold bg-indigo-50 text-indigo-600 border border-indigo-100 hover:bg-indigo-100 transition" do %>
            #<%= genre.name %>
          <% end %>
        <% end %>
      </div>

      <div class="flex items-center justify-between mt-2 w-full relative z-30">
        <div class="flex items-center whitespace-nowrap text-[11px] text-gray-400 font-bold bg-gray-50 px-2 py-0.5 rounded-md shrink-0">
          <svg class="w-3 h-3 mr-1.5 opacity-60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <span class="leading-none"><%= number_to_human(post.views_count) %>回再生</span>
        </div>
        <div class="flex items-center space-x-3　relative z-50">
          <%= render "likes/like", post: post %>

          <%# --- 管理人専用：削除ボタンを追加 --- %>
          <% if current_user&.admin? %>
            <%= button_to post_path(post), 
                          method: :delete, 
                          data: { turbo_confirm: "本当に削除しますか？" }, 
                          class: "flex items-center justify-center p-1.5 text-gray-300 hover:text-red-500 transition-colors bg-white/50 rounded-lg border border-transparent hover:border-red-100 hover:bg-red-50" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# スクリプトは1回だけ読み込む %>
<script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>

<style>
  /* 全てのカード内のXウィジェットを横幅100%に強制する */
  .twitter-video.twitter-video-rendered,
  twitterwidget {
    max-width: 100% !important;
    width: 100% !important;
    margin: 0 !important;
  }
</style>
