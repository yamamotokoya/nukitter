<div id="<%= dom_id post %>" class="group relative bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col h-full min-h-[400px] hover:border-indigo-300 transition-colors">
  
  <%# --- 全体リンク（ヘルパー使用） --- %>
  <%= link_to post_card_link_path(post), post_card_link_options(post) do %>
    <span class="sr-only"><%= post_card_button_label(post) %></span>
  <% end %>

  <div class="p-5 flex-1 flex flex-col relative">
    
    <%# 1. 配信者情報エリア (z-30) %>
    <div class="flex items-center mb-4 relative z-30">
      <%= link_to streamer_path(post.streamer), class: "w-9 h-9 rounded-full bg-indigo-600 flex-shrink-0 flex items-center justify-center text-white text-xs font-bold mr-3 hover:bg-indigo-500 transition shadow-sm overflow-hidden" do %>
        <% if post.streamer.icon.attached? %>
          <%= image_tag post.streamer.icon, class: "w-full h-full object-cover" %>
        <% else %>
          <%= post.streamer.name&.[](0) %>
        <% end %>
      <% end %>
      
      <div class="flex flex-col justify-center min-w-0">
        <div class="flex items-baseline space-x-2">
          <span class="text-sm font-extrabold text-gray-900 leading-tight truncate"><%= post.streamer.name %></span>
          <% if post.streamer.x_url.present? %>
             <span class="text-[11px] text-indigo-400 font-bold truncate">@<%= post.streamer.x_url.split('/').last %></span>
          <% end %>
        </div>
        <span class="text-[10px] text-gray-400 mt-0.5"><%= time_ago_in_words(post.created_at) %>前</span>
      </div>
    </div>

    <%# 2. 本文エリア %>
    <div class="text-gray-600 text-sm leading-relaxed mb-4 overflow-hidden relative z-0" 
         style="display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; min-height: 4.2em; max-height: 4.2em;">
      <%= post.content %>
    </div>

    <%# 3. サムネイルエリア (画像として表示し、中央に誘導ボタンを配置) %>
    <div class="aspect-video bg-slate-900 flex-shrink-0 w-full overflow-hidden rounded-lg relative z-0 flex items-center justify-center mb-4">
      <% if post.thumbnail.attached? %>
        <%= image_tag post.thumbnail, class: "w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center bg-slate-800">
          <% if post.streamer.icon.attached? %>
            <%= image_tag post.streamer.icon, class: "w-full h-full object-cover opacity-30 blur-sm" %>
          <% end %>
        </div>
      <% end %>

      <%# 中央のボタンデザイン（ヘルパーでアイコンとテキストを切り替え） %>
      <div class="absolute inset-0 flex items-center justify-center bg-black/10 group-hover:bg-black/30 transition-all pointer-events-none">
        <div class="relative px-4 py-2 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-md border border-white/30 shadow-lg transform group-hover:scale-110 transition-all duration-500">
          <span class="text-white text-xs font-bold mr-2"><%= post_card_button_label(post) %></span>
          <svg class="w-4 h-4 text-white fill-current" viewBox="0 0 24 24">
            <% if post_external_link?(post) %>
              <path d="M14 3h7v7h-2V6.41l-9.29 9.29-1.42-1.42L17.59 5H14V3zM5 5h5V3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-5h-2v5H5V5z"/>
            <% else %>
              <path d="M7 4.5V19.5C7 19.9 7.3 20.2 7.7 20.2C7.8 20.2 7.9 20.2 8.1 20.1L19.1 12.6C19.4 12.4 19.5 12.1 19.5 11.8C19.5 11.5 19.4 11.2 19.1 11L8.1 3.5C7.8 3.3 7.4 3.3 7.2 3.5C7.1 3.7 7 4.1 7 4.5Z"/>
            <% end %>
          </svg>
        </div>
      </div>
    </div>

    <%# 4. フッターエリア (z-30) %>
    <div class="mt-auto pt-4 border-t border-gray-100 relative z-30">
      <div class="flex flex-wrap gap-2 mb-4">
        <% post.genres.each do |genre| %>
          <%= link_to genre_path(genre), class: "px-2.5 py-1 rounded-full text-[10px] font-bold bg-indigo-50 text-indigo-600 border border-indigo-100 hover:bg-indigo-100 transition" do %>
            #<%= genre.name %>
          <% end %>
        <% end %>
      </div>

      <div class="flex items-center justify-between mt-2 w-full">
        <div class="flex items-center text-[11px] text-gray-400 font-bold bg-gray-50 px-2 py-0.5 rounded-md">
          <svg class="w-3 h-3 mr-1.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <span>詳細をチェック</span>
        </div>
        <div class="flex items-center space-x-3 relative z-50">
          <%= render "likes/like", post: post %>
        </div>
      </div>
    </div>
  </div>
</div>
